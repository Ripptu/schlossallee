rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: status
    // Fields:
    //   - isOpen: boolean (required) - Whether the Biergarten is currently open
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidSettingsUpdate() {
      return hasOnlyAllowedFields(['isOpen']) &&
             request.resource.data.isOpen is bool;
    }

    match /settings/{settingId} {
      // Allow public read so all visitors can see if it's open
      allow read: if true;
      
      // Allow public update ONLY for the status document, and ONLY if the payload is exactly a boolean 'isOpen'
      // This is a prototype approach to allow the frontend password to work without Firebase Auth.
      // In a production app, this should be protected by isAuthenticated() and isAdmin() checks.
      allow update: if settingId == 'status' && isValidSettingsUpdate();
      
      allow create, delete: if false;
    }
  }
}
